# ------------------------------------------------------------------------------
# IT Avenue Task Management System - Environment Variables Template
# Copy this file to a new file named `.env` and fill in your local values.
# ------------------------------------------------------------------------------

# 1. Database Configuration
# Local or cloud PostgreSQL database connection string.
# Example: postgresql://username:password@localhost:5432/it_mgt_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/it_mgt?schema=public"

# 2. Supabase Authentication Configuration
# Find these credentials in your Supabase Project Settings -> API page.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
